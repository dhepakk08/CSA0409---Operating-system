b) 1. open()
      Opens an existing file or creates a new file.
      Returns a file descriptor that is used for reading, writing, or other file operations.
2. close()
      Closes an opened file.
      Releases the file descriptor and frees system resources.

c) To write a C-based system call sequence to open a file, read its contents, and close it:

#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
int main()
{
    int fd, n;
    char buffer[100];
    // Open the file in read-only mode
    fd = open("student.txt", O_RDONLY);
    if (fd < 0) {
        printf("Error opening file.\n");
        return 1;
    }
    // Read the file contents
    n = read(fd, buffer, sizeof(buffer) - 1);
    if (n > 0) {
        buffer[n] = '\0';
        printf("File Contents:\n%s\n", buffer);
    }
    // Close the file
    close(fd);
    return 0;
}
